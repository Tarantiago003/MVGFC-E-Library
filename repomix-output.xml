                    <label class="form-label">Due Date</label>
                    <input type="date" class="form-input book-due">
                </div>
                <button type="button" class="remove-btn" onclick="this.parentElement.remove(); bookCount--;">Remove</button>
            `;
            bookEntries.appendChild(bookEntry);
            bookCount++;
        });

        // Generate notice preview
        noticeForm.addEventListener('submit', function(e) {
            e.preventDefault();

            const date = document.getElementById('noticeDate').value;
            const recipient = document.getElementById('recipientName').value;
            const department = document.getElementById('department').value;

            const formattedDate = new Date(date).toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
            });

            // Clear previous overlays
            overlayContainer.innerHTML = '';

            // Add DATE overlay (after "DATE:" label)
            addOverlay(formattedDate, '18%', '15.15%', '16px');

            // Add TO overlay (after "TO:" label)
            addOverlay(recipient, '15.5%', '16.9%', '16px');

