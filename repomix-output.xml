            overlayContainer.appendChild(overlay);
        }

        // Download as PDF
        downloadBtn.addEventListener('click', async function() {
            const { jsPDF } = window.jspdf;
            const pdf = new jsPDF({
                orientation: 'portrait',
                unit: 'mm',
                format: 'a4'
            });

            // Ensure background is loaded
            if (!backgroundImageData) {
                await loadBackgroundImage();
            }

            // Add background image
            if (backgroundImageData) {
                pdf.addImage(backgroundImageData, 'PNG', 0, 0, 210, 297);
            }

            const date = document.getElementById('noticeDate').value;
            const recipient = document.getElementById('recipientName').value;
            const department = document.getElementById('department').value;

            const formattedDate = new Date(date).toLocaleDateString('en-US', { 
                year: 'numeric', 
                month: 'long', 
                day: 'numeric' 
            });

            pdf.setFont(undefined, 'bold');
            pdf.setFontSize(11);

            // DATE (18%, 15.15%)
            pdf.text(formattedDate, 37.8, 49);

            // TO (15.5%, 16.9%)
            pdf.text(recipient, 32.5, 54);

            // DEPARTMENT (28.3%, 18.65%)
            pdf.text(department, 59.5, 59);

            // Books
            const bookAuthors = document.querySelectorAll('.book-author');
            const bookTitles = document.querySelectorAll('.book-title');
            const bookAccs = document.querySelectorAll('.book-acc');
            const bookDues = document.querySelectorAll('.book-due');

            pdf.setFontSize(10);

            // bookStartY = 30%
            let yPos = 92;

            // rowHeight = 1.7%
            const rowGap = 5.05;

            for (let i = 0; i < 5; i++) {
                if (i < bookAuthors.length && bookAuthors[i].value) {
                    // Author (22%)
                    pdf.text(bookAuthors[i].value, 36, yPos);

                    // Title (44%)
                    pdf.text(bookTitles[i].value, 72, yPos);

                    // Acc No (65%)
                    pdf.text(bookAccs[i].value, 133, yPos);

                    // Due Date (78%)
                    if (bookDues[i].value) {
                        const dueDate = new Date(bookDues[i].value).toLocaleDateString('en-US');
                        pdf.text(dueDate, 158, yPos);
                    }
                }
                yPos += rowGap;
            }

            // Checkboxes
            pdf.setFontSize(14);
            pdf.setFont(undefined, 'bold');

            // checkStartY = 40.2%
            yPos = 125;

            // checkGap = 2%
            const checkGap = 5.94;

            // X = 26.5%
            const checkX = 56.5;

            if (document.getElementById('reasonOverdue').checked) {
                pdf.text('✓', checkX, yPos);
            }
            yPos += checkGap;

            if (document.getElementById('reasonReserved').checked) {
                pdf.text('✓', checkX, yPos);
            }
            yPos += checkGap;

            if (document.getElementById('reasonNeeded').checked) {
                pdf.text('✓', checkX, yPos);
            }
            yPos += checkGap;

            if (document.getElementById('reasonOther').checked) {
                pdf.text('✓', checkX, yPos);

                const otherText = document.getElementById('otherReason').value;
                if (otherText) {
                    pdf.setFontSize(11);
                    pdf.setFont(undefined, 'normal');

                    // Other text (50%)
                    pdf.text(otherText, 100, yPos - 2);
                }
            }

            // Save
            const fileName = `Library_Notice_${recipient.replace(/\s+/g, '_')}.pdf`;
            pdf.save(fileName);
        });
    </script>
</body>
</html>
</file>

