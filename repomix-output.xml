                    <label class="form-label">Title</label>
                    <input type="text" class="form-input book-title" placeholder="Book title">
                </div>
                <div class="form-group">
                    <label class="form-label">Acc. No.</label>
                    <input type="text" class="form-input book-acc" placeholder="Acc number">
                </div>
